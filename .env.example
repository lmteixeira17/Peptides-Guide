# Required
SECRET_KEY=replace-with-a-strong-secret-key
PEPTIDES_DB_PASSWORD=replace-with-a-strong-database-password

# Optional
REDIS_URL=redis://localhost:6379/0
GA4_MEASUREMENT_ID=
ALLOWED_HOSTS=localhost,127.0.0.1,45.63.90.69,mlt.com.br,guiadepeptideos.com.br,www.guiadepeptideos.com.br

# Runtime defaults used by docker-compose.yml
PEPTIDES_DEBUG=False
FORCE_SCRIPT_NAME=/peptides
DB_ENGINE=django.db.backends.postgresql
DB_NAME=peptides
DB_USER=peptides
DB_HOST=db
DB_PORT=5432
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Trusted reverse-proxy CIDRs (comma-separated). Leave empty to use the safe
# default (loopback + RFC1918 + link-local). Set explicitly when running behind
# a known proxy/CDN, e.g. TRUSTED_PROXIES=173.245.48.0/20,103.21.244.0/22
TRUSTED_PROXIES=
